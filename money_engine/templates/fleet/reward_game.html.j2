<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ spec.name }} — Заработок</title>
  <meta name="description" content="{{ spec.name }}: играй и получай виртуальные награды">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, sans-serif; background: linear-gradient(135deg, #0f172a, #1a1a2e); color: #e2e8f0; min-height: 100vh; }
    .header { text-align: center; padding: 1.5rem; background: rgba(0,0,0,0.3); }
    h1 { font-size: 1.4rem; }
    .balance { font-size: 2rem; font-weight: 900; color: {{ theme }}; margin: 0.5rem 0; }
    .balance span { font-size: 0.9rem; color: #94a3b8; }
    .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; max-width: 360px; margin: 1.5rem auto; padding: 0 1rem; }
    .card { aspect-ratio: 1; background: #1e293b; border: 2px solid #334155; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 2rem; cursor: pointer; transition: all 0.2s; }
    .card.flipped { background: {{ theme }}22; border-color: {{ theme }}; }
    .card.matched { opacity: 0.3; pointer-events: none; }
    .actions { text-align: center; padding: 1rem; }
    .btn { background: {{ theme }}; color: #000; border: none; padding: 0.75rem 2rem; border-radius: 8px; font-weight: 700; cursor: pointer; margin: 0.5rem; }
    .ad { max-width: 320px; margin: 1rem auto; min-height: 100px; background: #1e293b; border: 1px dashed #475569; display: flex; align-items: center; justify-content: center; color: #64748b; font-size: 0.75rem; }
    .msg { text-align: center; color: #94a3b8; font-size: 0.85rem; margin: 0.5rem; }
  </style>
</head>
<body>
  <div class="header">
    <h1>🎮 {{ spec.name }}</h1>
    <div class="balance"><span>Баланс:</span> <span id="balance">0</span> ₽</div>
    <p class="msg">Собери пары — получай награды. Реклама = бонус.</p>
  </div>

  <div class="grid" id="grid"></div>
  <div class="actions">
    <button class="btn" onclick="claimReward()">Забрать бонус (+5₽)</button>
    <button class="btn" onclick="watchAd()" style="background:#334155;color:#e2e8f0">Смотреть рекламу (+15₽)</button>
  </div>
  <div class="ad">{{ ad_snippet | safe }}</div>

  <script>
    const SLUG = "{{ project_slug }}";
    const TRACK = "{{ track_url }}";
    let balance = 0;
    const emojis = ["🪙","💎","⭐","🎯","🔥","💰"];
    let cards = [], flipped = [], matched = 0;

    function track(e) { fetch(TRACK,{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({slug:SLUG,event:e})}).catch(()=>{}); }
    track("view");

    function init() {
      const pairs = [...emojis.slice(0,6), ...emojis.slice(0,6)].sort(() => Math.random() - 0.5);
      const grid = document.getElementById("grid");
      grid.innerHTML = "";
      pairs.forEach((e, i) => {
        const c = document.createElement("div");
        c.className = "card"; c.dataset.emoji = e; c.dataset.idx = i;
        c.textContent = "?";
        c.onclick = () => flip(c);
        grid.appendChild(c);
        cards.push(c);
      });
    }

    function flip(card) {
      if (card.classList.contains("flipped") || card.classList.contains("matched") || flipped.length >= 2) return;
      card.classList.add("flipped"); card.textContent = card.dataset.emoji;
      flipped.push(card);
      if (flipped.length === 2) {
        setTimeout(() => {
          if (flipped[0].dataset.emoji === flipped[1].dataset.emoji) {
            flipped.forEach(c => { c.classList.add("matched"); matched++; });
            balance += 2; document.getElementById("balance").textContent = balance;
            if (matched === 6) { balance += 10; document.getElementById("balance").textContent = balance; track("reward"); setTimeout(init, 1000); matched = 0; }
          } else { flipped.forEach(c => { c.classList.remove("flipped"); c.textContent = "?"; }); }
          flipped = [];
        }, 600);
      }
    }

    function claimReward() { balance += 5; document.getElementById("balance").textContent = balance; track("reward"); }
    function watchAd() { balance += 15; document.getElementById("balance").textContent = balance; track("ad_click"); }

    init();
    setInterval(() => track("view"), 90000);
  </script>
  {{ launch_button | safe }}
</body>
</html>
