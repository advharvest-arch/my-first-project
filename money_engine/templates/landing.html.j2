<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ opportunity.niche | title }} — Niche Intelligence Report</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #0f172a; color: #e2e8f0; line-height: 1.6; }
    .container { max-width: 720px; margin: 0 auto; padding: 2rem 1.5rem; }
    .badge { display: inline-block; background: #1e40af; color: #93c5fd; padding: 0.25rem 0.75rem; border-radius: 999px; font-size: 0.8rem; font-weight: 600; margin-bottom: 1rem; }
    h1 { font-size: 2rem; font-weight: 800; margin-bottom: 0.5rem; color: #f8fafc; }
    .score { font-size: 3rem; font-weight: 900; color: #22c55e; }
    .subtitle { color: #94a3b8; margin-bottom: 2rem; }
    .card { background: #1e293b; border: 1px solid #334155; border-radius: 12px; padding: 1.5rem; margin-bottom: 1.5rem; }
    .card h2 { font-size: 1.1rem; color: #93c5fd; margin-bottom: 0.75rem; }
    .metrics { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 2rem; }
    .metric { background: #1e293b; border: 1px solid #334155; border-radius: 8px; padding: 1rem; text-align: center; }
    .metric .value { font-size: 1.5rem; font-weight: 700; color: #f8fafc; }
    .metric .label { font-size: 0.75rem; color: #64748b; text-transform: uppercase; }
    .cta { display: block; background: #22c55e; color: #052e16; text-align: center; padding: 1rem 2rem; border-radius: 8px; font-size: 1.1rem; font-weight: 700; text-decoration: none; margin-top: 1.5rem; transition: background 0.2s; }
    .cta:hover { background: #16a34a; }
    .price { font-size: 2rem; font-weight: 800; color: #f8fafc; }
    ul { padding-left: 1.25rem; color: #cbd5e1; }
    li { margin-bottom: 0.5rem; }
    .footer { text-align: center; color: #475569; font-size: 0.8rem; margin-top: 3rem; }
  </style>
</head>
<body>
  <div class="container">
    <span class="badge">{{ opportunity.monetization_type | replace('_', ' ') | upper }}</span>
    <h1>{{ opportunity.niche | title }}</h1>
    <p class="subtitle">Niche Intelligence Report — {{ generated_at }}</p>

    <div class="metrics">
      <div class="metric">
        <div class="value">{{ opportunity.total_score }}</div>
        <div class="label">Opportunity Score</div>
      </div>
      <div class="metric">
        <div class="value">{{ opportunity.demand_score }}</div>
        <div class="label">Demand</div>
      </div>
      <div class="metric">
        <div class="value">{{ opportunity.monetization_score }}</div>
        <div class="label">Monetization</div>
      </div>
    </div>

    <div class="card">
      <h2>Market Opportunity</h2>
      <p>{{ opportunity.pain_point }}</p>
    </div>

    <div class="card">
      <h2>What's Inside</h2>
      <ul>
        <li>Demand & competition analysis for <strong>{{ opportunity.niche }}</strong></li>
        <li>Recommended monetization model: {{ opportunity.monetization_type | replace('_', ' ') }}</li>
        <li>30-day step-by-step action plan</li>
        <li>Revenue projections and pricing strategy</li>
        <li>Source signals from {{ opportunity.source }}</li>
      </ul>
    </div>

    <div class="card" style="text-align: center;">
      <div class="price">${{ opportunity.suggested_price_usd }}</div>
      <p style="color: #94a3b8; margin: 0.5rem 0;">One-time purchase — instant download</p>
      {% if payment_link %}
      <a href="{{ payment_link }}" class="cta">Get This Report →</a>
      {% else %}
      <a href="#" class="cta" onclick="alert('Add STRIPE_PAYMENT_LINK to .env to enable payments'); return false;">Get This Report →</a>
      {% endif %}
    </div>

    <p class="footer">Auto-generated by Money Engine</p>
  </div>
</body>
</html>
